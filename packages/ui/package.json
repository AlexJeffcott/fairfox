{
  "name": "@fairfox/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./event-delegation": "./src/event-delegation.ts",
    "./Button": "./src/components/Button/index.ts",
    "./Input": "./src/components/Input/index.ts"
  },
  "imports": {
    "#src/*": "./src/*"
  },
  "scripts": {
    "typecheck": "bun run css:types && tsc --noEmit && bun run ../../scripts/check-layout-ban.ts",
    "css:types": "tcm -p 'src/**/*.module.css' -s"
  },
  "dependencies": {
    "preact": "catalog:",
    "@preact/signals": "catalog:",
    "clsx": "catalog:",
    "marked": "catalog:",
    "dompurify": "catalog:"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "typed-css-modules": "catalog:",
    "typescript": "catalog:"
  }
}
