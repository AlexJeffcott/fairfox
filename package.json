{
  "name": "fairfox",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.3.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "catalog": {
    "typescript": "^5.9.3",
    "@types/bun": "latest",
    "@types/node": "^24.12.0",
    "preact": "^10.29.1",
    "@preact/signals": "^2.9.0",
    "htm": "^3.1.1",
    "marked": "^18.0.0",
    "elysia": "^1.4.28",
    "@elysiajs/static": "^1.4.7",
    "@fairfox/polly": "0.20.1",
    "@biomejs/biome": "2.4.8"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  },
  "scripts": {
    "dev": "bun --hot packages/web/src/server.ts",
    "start": "bun packages/web/src/server.ts",
    "check": "biome check --write .",
    "typecheck": "bun --filter='@fairfox/*' run typecheck",
    "test": "bun test",
    "backup": "mkdir -p backups && curl -fsSL $FAIRFOX_URL/todo/api/backup > backups/todo-$(date +%F).json && curl -fsSL $FAIRFOX_URL/struggle/api/backup/full > backups/struggle-$(date +%F).json"
  },
  "dependencies": {}
}
