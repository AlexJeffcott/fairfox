{
  "name": "fairfox",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.3.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "catalog": {
    "typescript": "^5.9.3",
    "@types/bun": "latest",
    "@types/node": "^24.12.0",
    "preact": "^10.29.1",
    "@preact/signals": "^2.9.0",
    "htm": "^3.1.1",
    "marked": "^18.0.0",
    "dompurify": "^3.2.4",
    "clsx": "^2.1.1",
    "typed-css-modules": "^0.9.1",
    "puppeteer": "^24.18.0",
    "elysia": "^1.4.28",
    "@elysiajs/static": "^1.4.7",
    "@fairfox/polly": "0.29.4",
    "@automerge/automerge": "^3.2.0",
    "@automerge/automerge-repo": "^2.5.0",
    "@automerge/automerge-repo-storage-indexeddb": "^2.5.0",
    "@automerge/automerge-repo-storage-nodefs": "^2.5.0",
    "@automerge/automerge-repo-network-websocket": "^2.5.0",
    "tweetnacl": "^1.0.3",
    "ws": "^8.18.0",
    "qrcode": "^1.5.4",
    "@types/qrcode": "^1.5.5",
    "jsqr": "^1.4.0",
    "werift": "^0.22.2",
    "@biomejs/biome": "2.4.8"
  },
  "devDependencies": {
    "@automerge/automerge": "catalog:",
    "@automerge/automerge-repo": "catalog:",
    "@automerge/automerge-repo-network-websocket": "catalog:",
    "@automerge/automerge-repo-storage-indexeddb": "catalog:",
    "@automerge/automerge-repo-storage-nodefs": "catalog:",
    "@biomejs/biome": "catalog:",
    "@fairfox/polly": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "puppeteer": "^24.41.0",
    "qrcode": "catalog:",
    "tweetnacl": "catalog:",
    "typescript": "catalog:",
    "ws": "catalog:"
  },
  "scripts": {
    "dev": "DATA_DIR=./data bun packages/web/src/server.ts",
    "start": "bun packages/web/src/server.ts",
    "check": "biome check --write . && bun scripts/check-no-as-casting.ts && bun scripts/check-no-inline-handlers.ts && bun scripts/check-shared-components.ts && bun scripts/check-no-relative-imports.ts && bun scripts/check-mesh-state.ts && bun scripts/check-no-server-state.ts && bun scripts/check-no-require.ts && bun scripts/check-secrets.ts",
    "typecheck": "bun --filter='@fairfox/*' run typecheck",
    "test": "bun test",
    "test:browser": "bun node_modules/@fairfox/polly/dist/tools/test/src/browser/run.js tests/browser",
    "backup": "mkdir -p backups && curl -fsSL ${FAIRFOX_URL:-https://fairfox-production-8273.up.railway.app}/todo/api/backup > backups/todo-$(date +%F).json && curl -fsSL ${FAIRFOX_URL:-https://fairfox-production-8273.up.railway.app}/struggle/api/backup/full > backups/struggle-$(date +%F).json",
    "relay": "bun scripts/relay.ts",
    "pair-cli": "FAIRFOX_URL=\"${FAIRFOX_URL:-http://localhost:3000}\" bun packages/cli/src/bin.ts"
  },
  "dependencies": {}
}
